{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@sheet-engine/core": ["./src/sheet-engine/core"],
      "@sheet-engine/core/*": ["./src/sheet-engine/core/*"],
      "@sheet-engine/react": ["./src/sheet-engine/react"],
      "@sheet-engine/react/*": ["./src/sheet-engine/react/*"],
      "@sheet-engine/formula-parser": ["./src/sheet-engine/formula-parser"],
      "@sheet-engine/formula-parser/*": ["./src/sheet-engine/formula-parser/*"]
    }
  },
  "include": ["./src/**/*", "demo/src/vite-env.d.ts"],
  "exclude": ["demo", "public", "node_modules", "dist"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
