      "roughness": 0, "opacity": 100, "groupIds": [], "roundness": null,
      "isDeleted": false, "boundElements": [], "link": null, "locked": false,
      "text": "+ params: sheetEditorRef, userId?\n+ persist userColor in ref (stable across re-renders)\n+ return broadcastSelection(sheetId, r, c)\n    → calls awareness.setLocalStateField('selection')\n+ handleAwarenessUpdate():\n    → skip local clientID\n    → build Presence[] from remote states\n    → diff prevPresencesRef ↔ newPresenceMap\n    → joined / moved → addPresences(presences)\n    → left room → removePresences(arr)\n    → update prevPresencesRef\n+ return activeUsers as ActiveUser[]\n    { name: string, color: string, userId?: string }",
      "fontSize": 13, "fontFamily": 2, "textAlign": "left",
      "verticalAlign": "top", "containerId": null,
      "originalText": "+ params: sheetEditorRef, userId?\n+ persist userColor in ref (stable across re-renders)\n+ return broadcastSelection(sheetId, r, c)\n    → calls awareness.setLocalStateField('selection')\n+ handleAwarenessUpdate():\n    → skip local clientID\n    → build Presence[] from remote states\n    → diff prevPresencesRef ↔ newPresenceMap\n    → joined / moved → addPresences(presences)\n    → left room → removePresences(arr)\n    → update prevPresencesRef\n+ return activeUsers as ActiveUser[]\n    { name: string, color: string, userId?: string }",
      "lineHeight": 1.25
    },

